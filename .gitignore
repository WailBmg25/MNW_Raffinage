# Artefacts volumineux régénérables (seed=42, via python -m src.preprocessing) :
# trop gros pour le hard-limit GitHub de 100 Mo/fichier. Les scalers/joblib (petits) restent versionnés.
data/processed/*.npy
!data/processed/.gitkeep

# Override local docker-compose (spécifique à une machine, ex. conflit de port)
docker-compose.override.yml

# OS
.DS_Store

# IDE
.vscode/
.idea/

# Fichiers d'instructions pour agents IA (Claude Code, etc.) — pas du contenu de projet
CLAUDE.md
AGENTS.md
.claude/

# Artefacts de compilation LaTeX (le rapport final versionné reste report.md/report.tex + images/)
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
*.blg
report/*.pdf
